{
  "expo": {
    "name": "Actress",
    "slug": "actress",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icons8-actress-100.png",
    "scheme": "actress",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/icons8-actress-100.png"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1a1028",
        "foregroundImage": "./assets/images/icons8-actress-100.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.gadbadrsorganization.actress",
      "softwareKeyboardLayoutMode": "resize"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/icons8-actress-16.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#1a1028",
          "image": "./assets/images/icons8-actress-64.png",
          "imageWidth": 64
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "83701532-76de-4423-af61-776945c116e6"
      }
    },
    "owner": "gadbadrs-organization"
  }
}
